#!/usr/bin/env bash
#
# ./stop — stop everything this checkout is running.
#
#   ./stop            stop the hub and any stage jobs it spawned
#   ./stop --list     show what would be stopped, stop nothing
#
# Only ever touches processes whose working directory is inside THIS checkout. Several
# clones of this repo on one machine is normal — and a hub from the wrong one answering on
# :8787 has already cost this project a debugging session — so "stop everything" here means
# "everything of mine", never "everything that looks like it".
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=scripts/_common.sh
. "$ROOT/scripts/_common.sh"

LIST=0
while [ $# -gt 0 ]; do
  case "$1" in
    --list)    LIST=1 ;;
    -h|--help) sed -n '2,9p' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
    *)         die "unknown option: $1 (try --help)" ;;
  esac
  shift
done

container_mode_guard stop "./cr down"

printf '\n  %sThe Cutting Room%s · stop\n' "$_B" "$_R"

step "Processes owned by this checkout"
say "${_D}$ROOT${_R}"

pids="$(owned_pids || true)"
if [ -z "$pids" ]; then
  ok "nothing running"
  # A hub from another clone on the usual port is not ours to stop, but staying silent
  # about it is how someone ends up testing the wrong tree for an hour.
  # This checkout's own port if it has pinned one, else the shared default.
  port="$(read_key HUB_PORT "$ROOT/ReelScraper/.env")"; port="${port:-8787}"
  other="$(hub_cwd "$port" 2>/dev/null || true)"
  if [ -n "$other" ]; then
    case "$other" in
      "$ROOT"/*) ;;
      *) warn ":$port is held by a different checkout — ${other%/ReelScraper}"
         say "${_D}not stopping it; run ./stop there if you meant that one${_R}" ;;
    esac
  fi
  printf '\n'
  exit 0
fi

for pid in $pids; do
  cmd="$(ps -o command= -p "$pid" 2>/dev/null | cut -c1-72 || echo '?')"
  printf '    %-8s %s\n' "$pid" "${_D}$cmd${_R}"
done

if [ "$LIST" -eq 1 ]; then
  printf '\n    %s--list: nothing was stopped%s\n\n' "$_D" "$_R"
  exit 0
fi

step "Stopping"
# TERM first so uvicorn runs its shutdown and stage subprocesses flush their logs.
for pid in $pids; do kill -TERM "$pid" 2>/dev/null || true; done

for _ in $(seq 1 20); do
  still="$(owned_pids || true)"
  [ -z "$still" ] && break
  sleep 0.25
done

still="$(owned_pids || true)"
if [ -n "$still" ]; then
  warn "still up after 5s — sending KILL"
  for pid in $still; do kill -KILL "$pid" 2>/dev/null || true; done
  sleep 0.5
  still="$(owned_pids || true)"
fi

if [ -n "$still" ]; then
  die "could not stop: $(echo "$still" | tr '\n' ' ')"
fi
ok "all stopped"
printf '\n    %sStart again with ./init — your data is untouched.%s\n\n' "$_D" "$_R"
