# ─── Identity & GitHub (single source of truth — nothing is hardcoded in the pipeline) ───
# Everything in this repo is authored under GIT_AUTHOR_* and published to the repo below.
# To connect a DIFFERENT account, change these values only — no identity string lives
# anywhere else in the codebase or in tooling.
#
# Apply after editing your real .env:   bash scripts/apply-identity.sh
GIT_AUTHOR_NAME=your-name
GIT_AUTHOR_EMAIL=you@users.noreply.github.com

# GitHub target for pushes / issue automation (used by gh; the pipeline never hardcodes these).
GITHUB_USER=your-github-username
GITHUB_REPO=TheCuttingRoom
# GITHUB_TOKEN=        # optional PAT; if unset, `gh auth login` credentials are used

# ─── Hub ───
BACKEND_API=http://127.0.0.1:8787

# ─── Per-agent secrets are declared by NAME in each agent's own .env (gitignored), never here.
#     e.g. AnalysisEngine/.env: GEMINI_API_KEY=...   AutoSearch/.env: IG_SESSIONID=... (+ optional GEMINI_API_KEY)
