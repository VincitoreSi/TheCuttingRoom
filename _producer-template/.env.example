# <AGENT_NAME> — environment (COPY to `.env` and fill in; `.env` is gitignored, never committed).
#
# Secrets are declared BY NAME ONLY in agent.json (`secrets:[{name, env_var, required}]`) and the
# real VALUES live here, local to this agent. The hub NEVER stores a secret — it only serves
# present/absent status (§10.4). This file documents the env-var NAMES; it holds NO real values.

# ---- Bootstrap (the ONLY two env inputs; everything else is hub config, §10.3) -------
BACKEND_API=http://127.0.0.1:8787
AGENT_NAME=<AGENT_NAME>

# ---- Secrets (rename/add to match agent.json `secrets[].env_var`) --------------------
# Example — an image/video generation or LLM provider key this agent needs:
# GEMINI_API_KEY=
# <ENV_VAR_NAME>=
