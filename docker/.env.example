# docker/.env.example — optional build/run knobs for the container lane.
#
#   cp docker/.env.example docker/.env      then edit
#
# Compose reads docker/.env automatically, because the project directory is the directory of
# docker-compose.yml. Values exported by ./cr (COMPOSE_PROJECT_NAME, HUB_PORT, TCR_UID,
# TCR_GID, TCR_BUILD_ID) take PRECEDENCE over anything in this file — the shell environment
# always wins over a .env file. Do not try to override those here; change ReelScraper/.env
# instead, which is where ./cr and the six bash entry points both read from.
#
# ==========================================================================================
# NO SECRETS IN THIS FILE. NOT ONE.
# ==========================================================================================
# API keys live in each agent's own gitignored .env, delivered through the bind mount, and
# are read for PRESENCE ONLY (ReelScraper/api/app.py:614 — "never returned, never logged").
# Anything you put here becomes part of the container's Config.Env, which means:
#   * `docker inspect` and `docker compose config` print it verbatim,
#   * the daemon persists it on host disk in config.v2.json, and
#   * _stage_env() (app.py:2119-2131) hands `dict(os.environ)` to EVERY spawned stage —
#     including `render`, whose argv arrives over the unauthenticated
#     POST /api/producers/register.
# That is the opposite of what containerizing this thing is for. See the "there is no
# env_file: block" note in docker-compose.yml.
#
# Windows: WSL2 only (DECISIONS.md D1). Clone INSIDE the WSL2 filesystem, run Docker Desktop
# on the WSL2 backend, drive everything with ./cr from a WSL2 shell. A clone under /mnt/c is
# unsupported and slow. There is no cr.cmd.


# ------------------------------------------------------------------------------------------
# Build knobs (used by `./cr build` / `./cr rebuild`; changing one needs a rebuild)
# ------------------------------------------------------------------------------------------

# ffmpeg: how the two binaries get into the image.
#   minimal — built from source in a cached stage with --disable-everything and only the
#             codecs/filters SimilarContent/engine/stitch.py actually uses. The default, and
#             what DECISIONS.md D2.2 asks for.
#   static  — a prebuilt static ffmpeg (~155 MB for the pair). The DOCUMENTED FALLBACK: use
#             it if a minimal build cannot produce an mp4 that plays in Safari/QuickTime, or
#             if a @needs_ffmpeg test fails on something the enable-list missed. Flipping it
#             is legitimate; just record why, because it is a large image regression.
# libx264 is GPL either way, and that stays true of any image built from this repo.
#FFMPEG_VARIANT=minimal

# 0 makes a smaller image with no ffmpeg/ffprobe at all. Rendering then refuses cleanly
# (SimilarContent/cli.py:440-441, before any paid API call) instead of failing mid-render.
# NEVER set this to 0 for the `health` image: health downgrades ffmpeg to SKIP when it
# is absent and the 12 @needs_ffmpeg tests in SimilarContent/tests/test_stitch.py silently do
# not run, which is a green-but-empty gate. docker-compose.yml hardcodes "1" for that service.
#WITH_FFMPEG=1

# 1 builds documentation/site into the image, which the hub mounts at /documentation
# (app.py:3396-3398, at IMPORT, so a docs rebuild always needs a hub restart). The entrypoint
# then copies it into the bind-mounted checkout on every start — the one place the container
# writes docs into your tree. Off by default.
#WITH_DOCS=0

# Image tag suffix. Two checkouts on one machine already get separate compose projects and
# separate volumes; this is for keeping two BUILDS side by side.
#TCR_IMAGE_TAG=local


# ------------------------------------------------------------------------------------------
# Run knobs
# ------------------------------------------------------------------------------------------

# Host port for the docs live-reload server (`./cr docsite`). The hub's own host port is
# HUB_PORT in ReelScraper/.env, not here — that is the file `health` and `stop` also read.
#DOCS_PORT=8000

# Container timezone. Affects LOG LEGIBILITY only: scheduling arithmetic is epoch-based, but
# core/logsetup.py formats timestamps with time.localtime() and no offset and builds the log
# FILENAME from local time, while the Dashboard renders times with toLocaleString() in the
# browser's zone. Set it to your own zone (e.g. Asia/Kolkata) if that mismatch annoys you.
#TZ=UTC

# Seconds the entrypoint gives the hub and every running stage to finish after SIGTERM before
# it escalates to SIGKILL. MUST stay comfortably below docker-compose.yml's
# stop_grace_period (120s), or the container runtime kills the whole cgroup first and the
# cooperative stop never happens. Raise BOTH if you routinely stop mid-scrape and want the
# per-creator save to complete.
#TCR_STOP_GRACE=100
