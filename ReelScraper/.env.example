# ReelScraper — environment (copy to .env; NEVER commit real values).
# Secrets are referenced BY ENV-VAR NAME only, never by value.
#
# ReelScraper is the HUB: it serves /api/* for every other agent, so unlike the
# sibling agents it has no BACKEND_API of its own — it *is* the backend. The two
# variables below only move where it listens.

# ─── Hub bind address (read by cli.py; --host / --port override these) ───
# The interface the hub binds. Keep the loopback default unless you know why:
# the hub has no authentication, so binding 0.0.0.0 exposes the whole /api/*
# contract — corpus, studio, gate, config — to your network.
# HUB_HOST=127.0.0.1

# The port the hub serves on. If it is already taken, cli.py falls back to an
# OS-assigned free port (use `cli.py start --strict-port` to fail instead).
# Every sibling agent must then point BACKEND_API at the port you chose.
# HUB_PORT=8787

# ─── Scraper credentials (per-platform; see SAFETY in CLAUDE.md) ───
# instagram — GUEST MODE ONLY. Never add a session cookie to the IG scraper.
# youtube   — key-free (InnerTube). No credentials.
# x         — has no guest path, so it REQUIRES a logged-in session. BURNER
#             ACCOUNT ONLY, never a personal/real one. Supply either via these
#             vars or a gitignored platforms/x/session.txt.
# X_AUTH_TOKEN=
# X_CT0=
