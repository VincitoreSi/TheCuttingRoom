# ---- secrets (NEVER commit) ----
.env
.env.*
!.env.example
*/session.txt
platforms/*/session.txt
**/session.txt

# Defence-in-depth: credential shapes this project does not currently produce, but
# which a contributor, an SDK, or a cloud CLI might drop into the tree. None of these
# match any tracked file today — they exist so that an accidental `git add -A` cannot
# stage a key. Keep them ABOVE the demo-data negation block at the bottom.
*.pem
*.key
*.p12
*.pfx
*.keystore
*.jks
id_rsa
id_ed25519
*_rsa
*_ed25519
.netrc
.npmrc
.pypirc
credentials
credentials.json
credentials.yml
credentials.yaml
service-account*.json
gcp-*.json
.aws/
.gcloud/
secrets.json
secrets.yml
secrets.yaml

