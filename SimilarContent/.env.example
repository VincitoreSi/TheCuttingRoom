# similar-content — secrets are declared BY NAME ONLY here and kept in a gitignored .env.
# The hub NEVER stores secret values (PIPELINE.md §10.4). This file documents the env-var
# NAMES the agent may resolve; copy to `.env` and fill in real values there.
#
# Which key is REQUIRED depends on the `active` provider in image_config.json.
# Default active provider = nvidia_nim -> NVIDIA_API_KEY is required.

# Active image provider (NVIDIA NIM / FLUX.1) — REQUIRED when image_config.active == "nvidia_nim"
NVIDIA_API_KEY=

# Optional alternate image providers (only needed if you switch image_config.active):
# GEMINI_API_KEY=      # nano_banana (Google Gemini 2.5 Flash Image)
# HF_TOKEN=            # huggingface (FLUX/SDXL)
# pollinations is keyless — no secret needed (used for free smoke renders).

# Bootstrap only (PIPELINE.md §10.3) — everything else is fetched from hub config at run start.
# BACKEND_API=http://127.0.0.1:8787
# AGENT_NAME=similar-content
