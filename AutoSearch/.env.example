# AutoSearch — environment (copy to .env; NEVER commit real values).
# Secrets are referenced BY ENV-VAR NAME only, never by value (PIPELINE.md §10.4).

# The hub base URL (the single integration point). Default shown.
BACKEND_API=http://127.0.0.1:8787

# This agent's registered name on the hub (bootstrap only — everything else is hub config).
AGENT_NAME=auto-search

# OPTIONAL — and OFF by default. Discovery runs on your seed keywords alone with no API
# call and no cost; that is the default and it is a complete, working mode.
#
# Set this ONLY if you also flip `term_expansion_enabled: true` on the agent's config desk,
# which spends Gemini credits to widen those seeds into more search terms. The flag is
# checked BEFORE the key, so exporting this for AnalysisEngine/SimilarContent — the normal
# state of this repo — never silently starts billing discovery too.
#
# Same key and same names as every other agent here (GEMINI_KEY / GOOGLE_API_KEY also work).
# Read from env only; the hub sees present/absent, never the value.
GEMINI_API_KEY=

# OPTIONAL burner session (§1 SAFETY — burner account ONLY, never personal/real). Absence
# is normal, not an error: AutoSearch runs GUEST-ONLY without it (shallower discovery).
# The ONLY other permitted channel is a gitignored session.txt (ReelScraper load_session
# format: must contain sessionid). NEVER commit either.
IG_SESSIONID=
IG_CSRFTOKEN=

# For the `smoke` command in CI (no network): install a canned fake IG transport instead
# of hitting instagram.com. Leave unset for a real smoke test against the live guest API.
# AUTOSEARCH_FAKE_IG=1
