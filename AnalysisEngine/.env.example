# AnalysisEngine — environment (copy to .env; NEVER commit real values).
# Secrets are referenced BY ENV-VAR NAME only, never by value (PIPELINE.md §10.4).

# The hub base URL (the single integration point). Default shown.
BACKEND_API=http://127.0.0.1:8787

# This agent's registered name on the hub (bootstrap only — everything else is hub config).
AGENT_NAME=analysis-engine

# REQUIRED for a live analysis run. Read from env only — the hub never sees the value.
# GEMINI_KEY and GOOGLE_API_KEY are also accepted as fallbacks.
GEMINI_API_KEY=

# Optional overrides (otherwise taken from hub config GET /api/config/agent/analysis-engine).
# GEMINI_MODEL=gemini-2.5-pro
